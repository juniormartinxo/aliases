#!/bin/bash
# bin/alias-remove

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$REPO_ROOT/lib/utils.sh"

alias_name="$1"
alias_file="$2"

if [[ -z "$alias_name" ]]; then
    echo "Usage: alias-remove <name> [filename]"
    exit 1
fi

if [[ ! -d "$ALIASES_DIR" ]]; then
    print_error "Aliases directory not found."
    exit 1
fi

target_file=""

# If filename provided, verify it
if [[ -n "$alias_file" ]]; then
    if [[ "$alias_file" != *.alias ]]; then
        alias_file="${alias_file}.alias"
    fi
    if [[ -f "$ALIASES_DIR/$alias_file" ]]; then
        target_file="$ALIASES_DIR/$alias_file"
    else
        print_error "File $alias_file does not exist."
        exit 1
    fi
else
    # Search for the alias
    # simple grep
    match=$(grep -l "alias $alias_name=" "$ALIASES_DIR"/*.alias | head -n 1)
    if [[ -n "$match" ]]; then
        target_file="$match"
    else
        print_error "Alias '$alias_name' not found."
        exit 1
    fi
fi

# Backup file
cp "$target_file" "${target_file}.bak"

# Remove the line
# Using sed with a temporary file to be portable and safe
tmp_file=$(mktemp)
# Remove lines matching exactly alias name=...
grep -v "^alias $alias_name=" "$target_file" > "$tmp_file"

if cmp -s "$target_file" "$tmp_file"; then
    print_error "Failed to remove alias (pattern mismatch?)."
    rm "$tmp_file"
    exit 1
else
    mv "$tmp_file" "$target_file"
    print_success "Removed '$alias_name' from $(basename "$target_file")"
    print_info "Run 'alias-reload' to apply changes."
fi
